          ],
          "cookies": [],
          "content": {
            "size": 16906,
            "mimeType": "application/javascript",
            "text": "/** User script */\n\n/**\n * Form type radio button\n *\n * @var int\n */\nconst FORM_TYPE_RADIO = 1;\n\n/**\n * Form type checkbox\n *\n * @var int\n */\nconst FORM_TYPE_CHECK = 2;\n\n/**\n * Form type textarea\n *\n * @var int\n */\nconst FORM_TYPE_TEXT = 3;\n\n/**\n * Hash changed event handler\n */\nwindow.addEventListener('hashchange', function() {\n    location.reload();\n});\n\nVue.component('radio', {\n    template: `\n  <div>\n    <div class=\"form__group\" v-for=\"options in list\">\n      <label>\n        <input :type=\"type\" :name=\"name\" :value=\"options.no\" class=\"form__radio\">\n        <span class=\"form__option-text\">{{ options.content }}</span>\n      </label>\n    </div>\n  </div>\n  `,\n    props: {\n        type: '',\n        name: '',\n        list: ''\n    }\n});\n\nVue.component('checkbox', {\n    template: `\n  <div>\n    <div class=\"form__group\" v-for=\"options in list\">\n      <label>\n        <input :type=\"type\" :name=\"name\" :value=\"options.no\" :id=\"options.no\" class=\"form__checkbox\">\n        <span class=\"form__option-text\">{{ options.content }}</span>\n      </label>\n    </div>\n  </div>\n  `,\n    props: {\n        type: '',\n        list: '',\n        name: ''\n    }\n});\n\nVue.component('textArea', {\n    template: `\n  <div>\n    <textarea :name=\"name\" maxlength=\"2000\"></textarea>\n  </div>\n  `,\n    props: {\n        name: ''\n    }\n});\n\nlet URL = window.location.protocol + \"//\" + window.location.host;\nlet sushiroSurvey,\n    answerStorage = [],\n    commentStorage = [],\n    surveyQuestions = [],\n    currentAnswers = [],\n    hash = 0,\n    surveyHash;\n\nlet headers = {\n    headers: {\n        'Content-Type': 'application/json',\n        'Authorization': 'Bearer ' + APIKEY\n    }\n};\n\nlet loading = document.querySelector('.loading');\nconst instance = axios.create({\n    baseURL: URL\n});\n\nconst survey = new Vue({\n    el: \"#app\",\n    data: {\n        buttonState: false,\n        startForm: false,\n        startSurvey: false,\n        surveyForms: false,\n        surveyComplete: false,\n        questionTitle: '',\n        questions: '',\n        progress: 0,\n        invitationCode: '',\n        errorInvitationCode: '',\n        price: '',\n        errorPrice: '',\n        visitTime: '',\n        errorVisitTime: '',\n        promoCode: '',\n        questionId: '',\n        firstQuestion: {},\n        errorMessage: []\n    },\n    methods: {\n        startingSurvey() {\n            let self = this;\n            sessionStorage.setItem('answerStorage', JSON.stringify(answerStorage));\n            sessionStorage.setItem('commentStorage', JSON.stringify(commentStorage));\n            window.history.pushState(null, null, \"#\");\n\n            // beforeSend\n            instance.interceptors.request.use(config => {\n                loading.classList.add(\"loading--active\");\n                return config;\n            });\n\n            // Success\n            instance.interceptors.response.use(response => {\n                loading.classList.remove(\"loading--active\");\n                return response;\n            });\n\n            instance.post(URL + \"/api/v1/surveys/start\", {\n                    invitation_code: self.invitationCode,\n                    total_price: self.price,\n                    visited_time: self.visitTime\n                }, headers)\n                .then(function(response) {\n                    let res = response.data.data.mst_question_page;\n                    self.questionTitle = res.display_title;\n                    self.questions = res.mst_questions;\n                    self.progress = response.data.data.progress;\n                    res.progress = response.data.data.progress;\n\n                    sushiroSurvey = {\n                        invitation_code: self.invitationCode,\n                        total_price: self.price,\n                        visited_time: self.visitTime,\n                        answers: []\n                    };\n\n                    sessionStorage.setItem('sushiroSurvey', JSON.stringify(sushiroSurvey));\n                    surveyQuestions.push(res);\n                    sessionStorage.setItem('surveyQuestions', JSON.stringify(surveyQuestions));\n\n                    self.startForm = false;\n                    self.startSurvey = true;\n                })\n                .catch(function(error) {\n                    self.errorInvitationCode = '';\n                    self.errorPrice = '';\n                    self.errorVisitTime = '';\n                    loading.classList.remove(\"loading--active\");\n\n                    if (error.response.status == 400) {\n                        for (let key in error.response.data.data) {\n                            switch (key) {\n                                case 'invitation_code':\n                                    for (let message in error.response.data.data[key]) {\n                                        self.errorInvitationCode = error.response.data.data[key][message]\n                                    }\n                                    break;\n                                case 'total_price':\n                                    for (let message in error.response.data.data[key]) {\n                                        self.errorPrice = error.response.data.data[key][message]\n                                    }\n                                    break;\n                                case 'visited_time':\n                                    for (let message in error.response.data.data[key]) {\n                                        self.errorVisitTime = error.response.data.data[key][message]\n                                    }\n                                    break;\n                            }\n                        }\n                    }\n                });\n        },\n        loadFirstQuestion() {\n            this.startSurvey = false;\n            this.surveyForms = true;\n\n            hash = parseInt(hash) + 1;\n            window.history.pushState(null, null, \"#\" + hash);\n            sessionStorage.setItem('surveyHash', hash);\n        },\n        loadQuestionpage(data = {}) {\n            let self = this;\n\n            // beforeSend\n            instance.interceptors.request.use(config => {\n                loading.classList.add(\"loading--active\");\n                return config;\n            });\n\n            // Success\n            instance.interceptors.response.use(response => {\n                loading.classList.remove(\"loading--active\");\n                return response;\n            });\n\n            instance.post(URL + \"/api/v1/surveys/next\", data, headers)\n                .then(function(response) {\n                    let status = response.data.data.status;\n\n                    if (status === 1) {\n                        let res = response.data.data.mst_question_page;\n                        res.progress = response.data.data.progress;\n                        surveyQuestions.push(res);\n\n                        sessionStorage.setItem('surveyQuestions', JSON.stringify(surveyQuestions));\n                        self.questionTitle = res.display_title;\n                        self.questions = res.mst_questions;\n                        self.progress = response.data.data.progress;\n                        hash = parseInt(hash) + 1;\n                        window.history.pushState(null, null, \"#\" + hash);\n                        sessionStorage.setItem('surveyHash', hash);\n                    } else {\n                        self.surveyForms = false;\n                        self.surveyComplete = true;\n                        self.promoCode = response.data.data.code;\n                        sessionStorage.clear();\n                        window.history.pushState(null, null, \"/\");\n                    }\n\n                    //clear checkboxes\n                    let checkBox = document.querySelectorAll('.form__checkbox');\n                    for (var i = 0; i < checkBox.length; i++) {\n                        checkBox[i].checked = false;\n                    };\n\n                    //clear radiobuttons\n                    let radioButton = document.querySelectorAll('.form__radio');\n                    for (var i = 0; i < radioButton.length; i++) {\n                        radioButton[i].checked = false;\n                    };\n                    window.scrollTo(0, 0);\n                })\n                .catch(function(error) {\n                    if (error.response.status == 400) {\n                        for (let key in error.response.data.data) {\n                            for (let message in error.response.data.data[key]) {\n                                self.errorMessage = error.response.data.data[key][message];\n                            }\n                        }\n                    }\n                });\n        },\n        submitAnswer(formData) {\n            this.errorMessage = '';\n\n            formData.forEach(function(value, key) {\n                let mstQuestion = survey.questions.find((question) => question.id === key);\n\n                if (mstQuestion) {\n                    let answer = {\n                        mst_question_id: mstQuestion.id,\n                        mst_menu_id: mstQuestion.mst_menu_id,\n                        answered_option_no: ''\n                    };\n\n                    let comment = {\n                        mst_question_id: mstQuestion.id,\n                        mst_menu_id: mstQuestion.mst_menu_id,\n                        answered_text: ''\n                    };\n\n                    switch (mstQuestion.form_type) {\n                        // Handle radio answers\n                        case FORM_TYPE_RADIO:\n                            answer.answered_option_no = value;\n                            answerStorage.push(answer);\n                            break;\n                            // Handle checkbox answers\n                        case FORM_TYPE_CHECK:\n                            if (!Array.isArray(value)) {\n                                value = [value];\n                            }\n                            answerStorage.push(\n                                ...value.map((no) => {\n                                    let answerCopy = {...answer };\n                                    answerCopy.answered_option_no = no;\n                                    return answerCopy;\n                                })\n                            );\n                            break;\n                            // Handle text answers\n                        case FORM_TYPE_TEXT:\n                            answerStorage.push(answer);\n                            if (value) {\n                                comment.answered_text = value;\n                                commentStorage.push(comment);\n                            }\n                            break;\n                    }\n                }\n            });\n\n            sessionStorage.setItem('answerStorage', JSON.stringify(answerStorage));\n            sessionStorage.setItem('commentStorage', JSON.stringify(commentStorage));\n            sushiroSurvey = JSON.parse(sessionStorage.getItem('sushiroSurvey'));\n            sushiroSurvey.answers = answerStorage;\n            sushiroSurvey.comments = commentStorage;\n            this.loadQuestionpage(sushiroSurvey);\n        },\n        getOptionType(i) {\n            switch (i) {\n                case 1:\n                    return \"radio\";\n                case 2:\n                    return \"checkbox\";\n                case 3:\n                    return \"textArea\";\n            }\n        },\n        validateForm() {\n            let myForm = document.querySelector('form');\n            let formData = new FormData(myForm);\n            let errorFields = [];\n            let requiredFields = [];\n            let setQuestionsAndAnswers = [];\n\n            surveyQuestions = JSON.parse(sessionStorage.getItem('surveyQuestions'));\n            let currentQuestions = surveyQuestions[surveyQuestions.length - 1];\n\n            for (let question of currentQuestions.mst_questions) {\n                if (question.is_required) {\n                    requiredFields.push(question.id);\n                }\n\n                setQuestionsAndAnswers[question.id] = \"\";\n            }\n\n            for (let pair of formData.entries()) {\n                if (setQuestionsAndAnswers.hasOwnProperty(pair[0])) {\n                    if (setQuestionsAndAnswers[pair[0]] !== '') {\n                        if (Array.isArray(setQuestionsAndAnswers[pair[0]])) {\n                            setQuestionsAndAnswers[pair[0]].push(pair[1]);\n                        } else {\n                            setQuestionsAndAnswers[pair[0]] = [setQuestionsAndAnswers[pair[0]], pair[1]];\n                        }\n                    } else {\n                        setQuestionsAndAnswers[pair[0]] = pair[1];\n                    }\n                }\n            }\n\n            Object.keys(setQuestionsAndAnswers).forEach(function(key) {\n                key = parseInt(key);\n\n                if (requiredFields.includes(key) && !setQuestionsAndAnswers[key]) {\n                    errorFields.push(key);\n                }\n            });\n\n            if (errorFields.length !== 0 && requiredFields.length !== 0) {\n                this.errorMessage = errorFields;\n                window.scrollTo(0, 0);\n            } else {\n                this.errorMessage = [];\n                this.submitAnswer(setQuestionsAndAnswers);\n            }\n        }\n    },\n    created() {\n        if (sessionStorage.getItem('sushiroSurvey') !== null) {\n            if (location.hash.length === 0) {\n                sessionStorage.setItem('answerStorage', '[]');\n                sessionStorage.setItem('commentStorage', '[]');\n                sessionStorage.setItem('surveyHash', '0');\n                sessionStorage.setItem('surveyQuestions', '[]');\n            }\n\n            let currentQuestion;\n            surveyQuestions = JSON.parse(sessionStorage.getItem('surveyQuestions'));\n            answerStorage = JSON.parse(sessionStorage.getItem('answerStorage'));\n            commentStorage = JSON.parse(sessionStorage.getItem('commentStorage'));\n            surveyHash = parseInt(sessionStorage.getItem('surveyHash'));\n            sushiroSurvey = JSON.parse(sessionStorage.getItem('sushiroSurvey'));\n\n            if (answerStorage.length !== 0) {\n                if (surveyHash > 0 && parseInt(location.hash.substring(1)) < surveyHash) {\n                    currentQuestion = surveyQuestions[(location.hash.substring(1)) - 1];\n                    hash = location.hash.substring(1);\n\n                    for (let answer in answerStorage) {\n                        if (answerStorage[answer].mst_question_id == currentQuestion.mst_questions[0].id) {\n                            answerStorage.splice(answer);\n                            sessionStorage.setItem('answerStorage', JSON.stringify(answerStorage));\n                            break;\n                        }\n                    }\n\n                    for (let comment in commentStorage) {\n                        for (let question in currentQuestion.mst_questions) {\n                            if (commentStorage[comment].mst_question_id == currentQuestion.mst_questions[question].id) {\n                                commentStorage.splice(comment);\n                                sessionStorage.setItem('commentStorage', JSON.stringify(commentStorage));\n                                break;\n                            }\n                        }\n                    }\n\n                    surveyQuestions.splice(surveyQuestions.length - (surveyQuestions.length - parseInt(hash)));\n                    sessionStorage.setItem('surveyQuestions', JSON.stringify(surveyQuestions));\n                    sessionStorage.setItem('surveyHash', hash);\n                } else {\n                    currentQuestion = surveyQuestions[surveyQuestions.length - 1];\n                    hash = surveyHash;\n                }\n\n                this.surveyForms = true;\n                this.startForm = false;\n                this.startSurvey = false;\n                this.questionTitle = currentQuestion.display_title;\n                this.questions = currentQuestion.mst_questions;\n                this.progress = currentQuestion.progress;\n            } else {\n                this.buttonState = true;\n                this.startForm = true;\n                this.surveyForms = false;\n                this.startSurvey = false;\n\n                this.invitationCode = sushiroSurvey.invitation_code;\n                this.price = sushiroSurvey.total_price;\n                this.visitTime = sushiroSurvey.visited_time;\n\n                sessionStorage.setItem('surveyHash', 0);\n                surveyQuestions.splice(0);\n                sessionStorage.setItem('surveyQuestions', JSON.stringify(surveyQuestions));\n                window.history.pushState(null, null, \"/\");\n            }\n        } else {\n            this.startForm = true;\n            window.history.pushState(null, null, \"/\");\n        }\n    }\n});"
          },
